# Copy to .env and fill in your keys.
# .env is git-ignored; never commit real values here.
#
# Required — core providers and tools.
# Optional — uncomment the block for each MCP server you enable
#            via `just mcp-add <name>`.

# ── AI Providers (required) ─────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── GitHub (required — gh CLI + MCP) ────────────────────────────

GITHUB_TOKEN=

# ── Brave Search MCP (optional) ──────────────────────────────────
# Enable: just mcp-add brave-search
# Sign up: https://brave.com/search/api/ (free tier: 2k/mo)

# BRAVE_API_KEY=

# ── Gmail MCP (optional) ────────────────────────────────────────
# Enable: just mcp-add gmail
# Setup: GCP OAuth2 credentials with Gmail API enabled

# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# ── Slack MCP (optional) ────────────────────────────────────────
# Enable: just mcp-add slack
# Setup: Create a Slack app with bot token scopes

# SLACK_BOT_TOKEN=
# SLACK_TEAM_ID=

# ── Linear MCP (optional) ───────────────────────────────────────
# Enable: just mcp-add linear
# Setup: https://linear.app/settings/api

# LINEAR_API_KEY=

# ── Jira MCP (optional) ─────────────────────────────────────────
# Enable: just mcp-add jira
# Setup: https://id.atlassian.com/manage-profile/security/api-tokens

# JIRA_HOST=https://your-company.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=

# ── Notion MCP (optional) ───────────────────────────────────────
# Enable: just mcp-add notion
# Setup: https://www.notion.so/my-integrations

# NOTION_API_KEY=

# ── Google Maps MCP (optional) ──────────────────────────────────
# Enable: just mcp-add google-maps
# Setup: GCP console → Maps JavaScript API + Geocoding API

# GOOGLE_MAPS_API_KEY=

# ── PostgreSQL (optional — project-local MCP) ───────────────────
# Used by mcp/templates/postgres-mcp.json or just mcp-add postgres

# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=postgres

# ── OpenCode model (optional) ───────────────────────────────────
# Set to override the default model used by OpenCode.

# OPENCODE_MODEL=
