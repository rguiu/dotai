{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/mcp-server-postgres"
      ],
      "env": {
        "PGHOST": "{env:PGHOST:localhost}",
        "PGPORT": "{env:PGPORT:5432}",
        "PGUSER": "{env:PGUSER}",
        "PGPASSWORD": "{env:PGPASSWORD}",
        "PGDATABASE": "{env:PGDATABASE}"
      }
    }
  }
}
