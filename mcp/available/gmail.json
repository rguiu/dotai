{
  "name": "gmail",
  "description": "Read, search, and manage Gmail messages",
  "server": {
    "command": "npx",
    "args": ["-y", "@anthropic-ai/mcp-server-gmail"],
    "env": {
      "GMAIL_CLIENT_ID": "{env:GMAIL_CLIENT_ID}",
      "GMAIL_CLIENT_SECRET": "{env:GMAIL_CLIENT_SECRET}",
      "GMAIL_REFRESH_TOKEN": "{env:GMAIL_REFRESH_TOKEN}"
    }
  },
  "requires": {
    "binaries": ["npx"],
    "env_vars": ["GMAIL_CLIENT_ID", "GMAIL_CLIENT_SECRET", "GMAIL_REFRESH_TOKEN"]
  },
  "setup_notes": "Requires GCP OAuth2 credentials with Gmail API enabled. Generate refresh token via OAuth playground."
}
